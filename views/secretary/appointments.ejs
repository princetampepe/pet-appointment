<%- include('../layouts/main', { body: `
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar-check"></i> All Appointments</h2>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form action="/secretary/appointments" method="GET" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select class="form-select" name="status">
                    <option value="">All Statuses</option>
                    <option value="pending" ${filters.status === 'pending' ? 'selected' : ''}>Pending</option>
                    <option value="confirmed" ${filters.status === 'confirmed' ? 'selected' : ''}>Confirmed</option>
                    <option value="completed" ${filters.status === 'completed' ? 'selected' : ''}>Completed</option>
                    <option value="cancelled" ${filters.status === 'cancelled' ? 'selected' : ''}>Cancelled</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Doctor</label>
                <select class="form-select" name="doctor_id">
                    <option value="">All Doctors</option>
                    ${doctors.map(doc => '<option value="' + doc.id + '" ' + (filters.doctor_id == doc.id ? 'selected' : '') + '>Dr. ' + doc.first_name + ' ' + doc.last_name + '</option>').join('')}
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Date</label>
                <input type="date" class="form-control" name="date" value="${filters.date || ''}">
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2"><i class="bi bi-filter"></i> Filter</button>
                <a href="/secretary/appointments" class="btn btn-outline-secondary"><i class="bi bi-x"></i> Clear</a>
            </div>
        </form>
    </div>
</div>

${appointments.length === 0 ? `
<div class="text-center py-5">
    <i class="bi bi-calendar display-1 text-muted"></i>
    <h4 class="mt-3">No Appointments Found</h4>
    <p class="text-muted">No appointments match your filters.</p>
</div>
` : `
<div class="table-responsive">
    <table class="table table-hover bg-white shadow-sm">
        <thead class="table-light">
            <tr>
                <th>Date & Time</th>
                <th>Pet</th>
                <th>Owner</th>
                <th>Doctor</th>
                <th>Reason</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            ${appointments.map(apt => `
            <tr>
                <td>
                    <strong>${apt.appointment_date}</strong><br>
                    <small class="text-muted">${apt.appointment_time}</small>
                </td>
                <td>${apt.pet_name} <small class="text-muted">(${apt.pet_species})</small></td>
                <td>
                    ${apt.patient_first_name} ${apt.patient_last_name}<br>
                    <small class="text-muted">${apt.patient_phone || 'No phone'}</small>
                </td>
                <td>Dr. ${apt.doctor_first_name} ${apt.doctor_last_name}</td>
                <td>${apt.reason}</td>
                <td>
                    <span class="badge bg-${apt.status === 'pending' ? 'warning' : apt.status === 'confirmed' ? 'success' : apt.status === 'completed' ? 'info' : 'danger'}">
                        ${apt.status}
                    </span>
                </td>
                <td>
                    <div class="btn-group btn-group-sm">
                        <a href="/secretary/appointments/${apt.id}" class="btn btn-outline-primary" title="View Details">
                            <i class="bi bi-eye"></i>
                        </a>
                        ${apt.status === 'pending' ? `
                        <form action="/secretary/appointments/${apt.id}/confirm" method="POST" class="d-inline">
                            <button type="submit" class="btn btn-outline-success" title="Confirm">
                                <i class="bi bi-check"></i>
                            </button>
                        </form>
                        ` : ''}
                        ${apt.status !== 'cancelled' && apt.status !== 'completed' ? `
                        <form action="/secretary/appointments/${apt.id}/cancel" method="POST" class="d-inline" onsubmit="return confirm('Cancel this appointment?')">
                            <button type="submit" class="btn btn-outline-danger" title="Cancel">
                                <i class="bi bi-x"></i>
                            </button>
                        </form>
                        ` : ''}
                    </div>
                </td>
            </tr>
            `).join('')}
        </tbody>
    </table>
</div>
`}
` }) %>
