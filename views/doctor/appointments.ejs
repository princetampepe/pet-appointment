<%- include('../layouts/main', { body: `
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar-check"></i> All Appointments</h2>
    <a href="/doctor/appointments/pending" class="btn btn-warning">
        <i class="bi bi-clock-history"></i> View Pending Only
    </a>
</div>

${appointments.length === 0 ? `
<div class="text-center py-5">
    <i class="bi bi-calendar display-1 text-muted"></i>
    <h4 class="mt-3">No Appointments</h4>
    <p class="text-muted">You don't have any appointments assigned.</p>
</div>
` : `
<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Date & Time</th>
                <th>Pet</th>
                <th>Owner</th>
                <th>Reason</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            ${appointments.map(apt => `
            <tr>
                <td>
                    <strong>${apt.appointment_date}</strong><br>
                    <small class="text-muted">${apt.appointment_time}</small>
                </td>
                <td>
                    ${apt.pet_name}<br>
                    <small class="text-muted">${apt.pet_species}${apt.pet_breed ? ' - ' + apt.pet_breed : ''}</small>
                </td>
                <td>
                    ${apt.patient_first_name} ${apt.patient_last_name}<br>
                    <small class="text-muted"><i class="bi bi-telephone"></i> ${apt.patient_phone || 'N/A'}</small>
                </td>
                <td>${apt.reason}</td>
                <td>
                    <span class="badge bg-${apt.status === 'pending' ? 'warning' : apt.status === 'confirmed' ? 'success' : apt.status === 'completed' ? 'info' : 'danger'}">
                        ${apt.status}
                    </span>
                </td>
                <td>
                    <div class="btn-group btn-group-sm">
                        <a href="/doctor/appointments/${apt.id}" class="btn btn-outline-primary" title="View Details">
                            <i class="bi bi-eye"></i>
                        </a>
                        ${apt.status === 'pending' ? `
                        <form action="/doctor/appointments/${apt.id}/confirm" method="POST" class="d-inline">
                            <button type="submit" class="btn btn-outline-success" title="Confirm">
                                <i class="bi bi-check"></i>
                            </button>
                        </form>
                        ` : ''}
                        ${apt.status === 'confirmed' ? `
                        <form action="/doctor/appointments/${apt.id}/complete" method="POST" class="d-inline">
                            <button type="submit" class="btn btn-outline-info" title="Mark Complete">
                                <i class="bi bi-check-all"></i>
                            </button>
                        </form>
                        ` : ''}
                    </div>
                </td>
            </tr>
            `).join('')}
        </tbody>
    </table>
</div>
`}
` }) %>
