<%- include('../layouts/main', { body: `
<div class="mb-4">
    <a href="/doctor/appointments/${appointment.id}" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Appointment
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-file-medical"></i> Add Medical Record</h5>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-info mb-4">
                    <div class="row">
                        <div class="col-md-6">
                            <strong>Pet:</strong> ${appointment.pet_name} (${appointment.pet_species})<br>
                            <strong>Owner:</strong> ${appointment.patient_first_name} ${appointment.patient_last_name}
                        </div>
                        <div class="col-md-6">
                            <strong>Date:</strong> ${appointment.appointment_date}<br>
                            <strong>Reason:</strong> ${appointment.reason}
                        </div>
                    </div>
                </div>
                
                <form action="/doctor/appointments/${appointment.id}/add-record" method="POST">
                    <div class="mb-3">
                        <label for="diagnosis" class="form-label">Diagnosis *</label>
                        <textarea class="form-control" id="diagnosis" name="diagnosis" rows="3" required placeholder="Enter diagnosis"></textarea>
                    </div>
                    
                    <div class="mb-3">
                        <label for="treatment" class="form-label">Treatment</label>
                        <textarea class="form-control" id="treatment" name="treatment" rows="3" placeholder="Describe treatment provided"></textarea>
                    </div>
                    
                    <div class="mb-3">
                        <label for="prescription" class="form-label">Prescription</label>
                        <textarea class="form-control" id="prescription" name="prescription" rows="2" placeholder="Medications prescribed"></textarea>
                    </div>
                    
                    <div class="mb-4">
                        <label for="notes" class="form-label">Additional Notes</label>
                        <textarea class="form-control" id="notes" name="notes" rows="2" placeholder="Any additional notes or follow-up instructions"></textarea>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Save Record
                        </button>
                        <a href="/doctor/appointments/${appointment.id}" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
` }) %>
