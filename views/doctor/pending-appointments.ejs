<%- include('../layouts/main', { body: `
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clock-history text-warning"></i> Pending Appointments</h2>
    <a href="/doctor/appointments" class="btn btn-outline-primary">
        <i class="bi bi-list"></i> View All
    </a>
</div>

${appointments.length === 0 ? `
<div class="text-center py-5">
    <i class="bi bi-check-circle display-1 text-success"></i>
    <h4 class="mt-3">All Caught Up!</h4>
    <p class="text-muted">No pending appointments to review.</p>
</div>
` : `
<div class="row g-4">
    ${appointments.map(apt => `
    <div class="col-md-6 col-lg-4">
        <div class="card border-warning h-100">
            <div class="card-header bg-warning bg-opacity-10">
                <div class="d-flex justify-content-between align-items-center">
                    <strong><i class="bi bi-calendar"></i> ${apt.appointment_date}</strong>
                    <span class="badge bg-warning text-dark">${apt.appointment_time}</span>
                </div>
            </div>
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-heart text-danger"></i> ${apt.pet_name}</h5>
                <p class="card-text">
                    <small class="text-muted">${apt.pet_species}${apt.pet_breed ? ' - ' + apt.pet_breed : ''}</small>
                </p>
                <hr>
                <p class="mb-1"><strong>Owner:</strong> ${apt.patient_first_name} ${apt.patient_last_name}</p>
                <p class="mb-1"><small><i class="bi bi-telephone"></i> ${apt.patient_phone || 'N/A'}</small></p>
                <hr>
                <p class="mb-0"><strong>Reason:</strong> ${apt.reason}</p>
            </div>
            <div class="card-footer bg-white">
                <div class="d-flex gap-2">
                    <form action="/doctor/appointments/${apt.id}/confirm" method="POST" class="flex-fill">
                        <button type="submit" class="btn btn-success w-100">
                            <i class="bi bi-check"></i> Confirm
                        </button>
                    </form>
                    <a href="/doctor/appointments/${apt.id}" class="btn btn-outline-primary">
                        <i class="bi bi-eye"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
    `).join('')}
</div>
`}
` }) %>
