<%- include('../layouts/main', { body: `
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar-check"></i> My Appointments</h2>
    <a href="/patient/appointments/book" class="btn btn-primary">
        <i class="bi bi-calendar-plus"></i> Book Appointment
    </a>
</div>

${appointments.length === 0 ? `
<div class="text-center py-5">
    <i class="bi bi-calendar display-1 text-muted"></i>
    <h4 class="mt-3">No Appointments</h4>
    <p class="text-muted">You don't have any appointments scheduled.</p>
    <a href="/patient/appointments/book" class="btn btn-primary">
        <i class="bi bi-calendar-plus"></i> Book Your First Appointment
    </a>
</div>
` : `
<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Date & Time</th>
                <th>Pet</th>
                <th>Doctor</th>
                <th>Reason</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            ${appointments.map(apt => `
            <tr>
                <td>
                    <strong>${apt.appointment_date}</strong><br>
                    <small class="text-muted">${apt.appointment_time}</small>
                </td>
                <td>${apt.pet_name} <small class="text-muted">(${apt.pet_species})</small></td>
                <td>Dr. ${apt.doctor_first_name} ${apt.doctor_last_name}</td>
                <td>${apt.reason}</td>
                <td>
                    <span class="badge bg-${apt.status === 'pending' ? 'warning' : apt.status === 'confirmed' ? 'success' : apt.status === 'completed' ? 'info' : 'danger'}">
                        ${apt.status}
                    </span>
                </td>
                <td>
                    ${apt.status === 'pending' || apt.status === 'confirmed' ? `
                    <div class="btn-group btn-group-sm">
                        <a href="/patient/appointments/reschedule/${apt.id}" class="btn btn-outline-primary" title="Reschedule">
                            <i class="bi bi-calendar-event"></i>
                        </a>
                        <form action="/patient/appointments/cancel/${apt.id}" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to cancel this appointment?')">
                            <button type="submit" class="btn btn-outline-danger" title="Cancel">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        </form>
                    </div>
                    ` : '-'}
                </td>
            </tr>
            `).join('')}
        </tbody>
    </table>
</div>
`}
` }) %>
