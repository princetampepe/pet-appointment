<%- include('../layouts/main', { body: `
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-calendar-event"></i> Reschedule Appointment</h5>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-info">
                    <strong>Current Appointment:</strong><br>
                    Pet: ${appointment.pet_name} (${appointment.pet_species})<br>
                    Doctor: Dr. ${appointment.doctor_first_name} ${appointment.doctor_last_name}<br>
                    Date: ${appointment.appointment_date} at ${appointment.appointment_time}<br>
                    Reason: ${appointment.reason}
                </div>
                
                <form action="/patient/appointments/reschedule/${appointment.id}" method="POST">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="appointment_date" class="form-label">New Date *</label>
                            <input type="date" class="form-control" id="appointment_date" name="appointment_date" required min="${new Date().toISOString().split('T')[0]}" value="${appointment.appointment_date}">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="appointment_time" class="form-label">New Time *</label>
                            <select class="form-select" id="appointment_time" name="appointment_time" required>
                                <option value="">Select a new date first</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-calendar-check"></i> Reschedule
                        </button>
                        <a href="/patient/appointments" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
                
                <script>
                    const dateInput = document.getElementById('appointment_date');
                    const timeSelect = document.getElementById('appointment_time');
                    const doctorId = parseInt('${appointment.doctor_id}');
                    const currentTime = '${appointment.appointment_time}';
                    
                    async function loadAvailableSlots() {
                        const date = dateInput.value;
                        
                        if (!date) {
                            timeSelect.innerHTML = '<option value="">Select a date first</option>';
                            return;
                        }
                        
                        try {
                            const response = await fetch('/patient/api/available-slots?doctor_id=' + doctorId + '&date=' + date);
                            const data = await response.json();
                            
                            if (data.availableSlots && data.availableSlots.length > 0) {
                                // Add current time slot if not in the list (it's the existing booking)
                                let slots = data.availableSlots;
                                if (!slots.includes(currentTime)) {
                                    slots.push(currentTime);
                                    slots.sort();
                                }
                                
                                timeSelect.innerHTML = '<option value="">Select a time</option>' + 
                                    slots.map(slot => '<option value="' + slot + '"' + (slot === currentTime ? ' selected' : '') + '>' + slot + '</option>').join('');
                            } else {
                                timeSelect.innerHTML = '<option value="">No available slots</option>';
                            }
                        } catch (error) {
                            console.error('Error loading slots:', error);
                        }
                    }
                    
                    dateInput.addEventListener('change', loadAvailableSlots);
                    loadAvailableSlots();
                </script>
            </div>
        </div>
    </div>
</div>
` }) %>
