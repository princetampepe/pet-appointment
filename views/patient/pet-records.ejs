<%- include('../layouts/main', { body: `
<div class="mb-4">
    <a href="/patient/pets" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Pets
    </a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <div class="pet-avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 60px; height: 60px;">
                <i class="bi bi-heart-fill fs-4"></i>
            </div>
            <div>
                <h4 class="mb-0">${pet.name}</h4>
                <p class="text-muted mb-0">${pet.species}${pet.breed ? ' - ' + pet.breed : ''}</p>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
        <h5 class="mb-0"><i class="bi bi-file-medical"></i> Medical Records</h5>
    </div>
    <div class="card-body">
        ${records.length === 0 ? `
        <div class="text-center py-5">
            <i class="bi bi-file-medical display-1 text-muted"></i>
            <h5 class="mt-3">No Medical Records</h5>
            <p class="text-muted">No medical records have been added for ${pet.name} yet.</p>
        </div>
        ` : `
        <div class="timeline">
            ${records.map(record => `
            <div class="card mb-3 border-start border-primary border-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="mb-0">
                            <i class="bi bi-calendar text-primary"></i> ${record.record_date}
                        </h6>
                        <small class="text-muted">Dr. ${record.doctor_first_name} ${record.doctor_last_name}</small>
                    </div>
                    
                    ${record.diagnosis ? `
                    <div class="mb-2">
                        <strong class="text-danger"><i class="bi bi-activity"></i> Diagnosis:</strong>
                        <p class="mb-0">${record.diagnosis}</p>
                    </div>
                    ` : ''}
                    
                    ${record.treatment ? `
                    <div class="mb-2">
                        <strong class="text-success"><i class="bi bi-bandaid"></i> Treatment:</strong>
                        <p class="mb-0">${record.treatment}</p>
                    </div>
                    ` : ''}
                    
                    ${record.prescription ? `
                    <div class="mb-2">
                        <strong class="text-info"><i class="bi bi-capsule"></i> Prescription:</strong>
                        <p class="mb-0">${record.prescription}</p>
                    </div>
                    ` : ''}
                    
                    ${record.notes ? `
                    <div>
                        <strong class="text-muted"><i class="bi bi-sticky"></i> Notes:</strong>
                        <p class="mb-0 text-muted">${record.notes}</p>
                    </div>
                    ` : ''}
                </div>
            </div>
            `).join('')}
        </div>
        `}
    </div>
</div>
` }) %>
